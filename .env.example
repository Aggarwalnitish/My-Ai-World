# ── Anthropic Claude API ─────────────────────────────────────────────
# Get a key at https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Database (Supabase Postgres) ─────────────────────────────────────
# In Supabase: Project Settings → Database → Connection string.
# DATABASE_URL = the "Transaction" pooler URL (port 6543), append ?pgbouncer=true
# DIRECT_URL   = the "Session"/direct URL (port 5432), used for migrations
DATABASE_URL=
DIRECT_URL=

# ── Auth ─────────────────────────────────────────────────────────────
# The single password you'll use to log in.
APP_PASSWORD=
# A random string of 32+ characters used to sign the session cookie.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
